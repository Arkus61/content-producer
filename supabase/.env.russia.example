# ── PostgreSQL ──
POSTGRES_PASSWORD=changethis-postgres-strong-password-64-chars-long

# ── Kong / API ──
API_EXTERNAL_URL=http://your-russian-server-ip:8000

# ── Auth ──
SITE_URL=http://your-russian-server-ip:3000
JWT_SECRET=changethis-jwt-secret-32-characters-x

# ── SMTP (optional) ──
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=admin@your-domain.ru
SMTP_PASS=app-password-here
SMTP_SENDER=Content Producer

# ── App Config ──
MAILER_AUTOCONFIRM=false
DISABLE_SIGNUP=false
REDIRECT_URI_ALLOW_LIST=*
